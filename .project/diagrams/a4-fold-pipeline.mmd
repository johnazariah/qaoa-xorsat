graph BT
    L["LEAF: B = 2^-p everywhere"]

    Rp["Round p: constraint fold + variable fold + mixer"]
    Rm["Round p-1: constraint fold + variable fold + mixer"]
    dots["... repeat for each round ..."]
    R1["Round 1: constraint fold + variable fold + mixer"]
    ROOT["ROOT observable --> satisfaction fraction"]

    L --> Rp --> Rm --> dots --> R1 --> ROOT

    style L fill:#f0fdf4,stroke:#86efac,color:#14532d
    style Rp fill:#fefce8,stroke:#d97706,color:#78350f
    style Rm fill:#fefce8,stroke:#d97706,color:#78350f
    style dots fill:#f9fafb,stroke:#d1d5db,color:#374151,stroke-dasharray: 5 5
    style R1 fill:#fefce8,stroke:#d97706,color:#78350f
    style ROOT fill:#dbeafe,stroke:#2563eb,color:#1e3a5f
